# Application
APP_ENV=local
APP_NAME=miles-app
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+psycopg://miles_app:miles_app_local@localhost:5432/miles_app

# Railway PostgreSQL optional variables
PGHOST=
PGPORT=
PGUSER=
PGPASSWORD=
PGDATABASE=

# Scraping
SCRAPER_TIMEOUT=30
SCRAPER_RETRY_LIMIT=3
DEFAULT_SEARCH_INTERVAL=60

# Notifications
RESEND_API_KEY=
NOTIFICATION_FROM_EMAIL=

# Datadog
DD_API_KEY=
DD_SITE=datadoghq.com
DD_SERVICE=miles-app
DD_ENV=local
DD_VERSION=0.1.0
